Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{"1", ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "x"}], ",", 
     RowBox[{"x", "^", "2"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.988810166319023*^9, 3.988810166319023*^9}},
