Cell[BoxData[
 RowBox[{
  TemplateBox[{"1", "x", "0", "3", "z", 
    RowBox[{"2", " ", "x"}], "5", "y", 
    RowBox[{"-", "x"}], 
    SuperscriptBox["x", "2"]},
   "InactiveIntegrate",
   DisplayFunction->(RowBox[{
      SubsuperscriptBox[
       StyleBox["\[Integral]", "Inactive"], #3, #4], 
      RowBox[{
        SubsuperscriptBox[
         StyleBox["\[Integral]", "Inactive"], #6, #7], 
        RowBox[{
          SubsuperscriptBox[
           StyleBox["\[Integral]", "Inactive"], #9, #10], 
          RowBox[{#, 
            RowBox[{
              StyleBox["\[DifferentialD]", "Inactive"], #8}], 
            RowBox[{
              StyleBox["\[DifferentialD]", "Inactive"], #5}], 
            RowBox[{
              StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]}]}]& ),
   InterpretationFunction->(RowBox[{
      RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
      RowBox[{#, ",", 
        RowBox[{"{", 
          RowBox[{#2, ",", #3, ",", #4}], "}"}], ",", 
        RowBox[{"{", 
          RowBox[{#5, ",", #6, ",", #7}], "}"}], ",", 
        RowBox[{"{", 
          RowBox[{#8, ",", #9, ",", #10}], "}"}]}], "]"}]& )], "\[Equal]", 
