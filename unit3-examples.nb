 CellLabel->"In[31]:=",ExpressionUUID->"28c06852-5dde-9245-b905-7d3ff009e730"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"r", "[", "\[Theta]_", "]"}], ":=", 
      RowBox[{"a", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"b", " ", "\[Theta]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
