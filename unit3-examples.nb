Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"integrand", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "x"}], ",", 
     RowBox[{"x", "^", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"myIntegral", "=", 
   RowBox[{
    RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
    RowBox[{"integrand", ",", "oB", ",", "iB"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"myIntegral", "==", 
  RowBox[{"Activate", "[", "myIntegral", "]"}]}]}], "Input",
 CellChangeTimes->{{3.988810183853384*^9, 3.9888102166641827`*^9}, {
  3.988810294681057*^9, 3.9888103605260963`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"a5fdfcfa-cb8c-7949-9719-ccb400004081"],

Cell[BoxData[
 RowBox[{
  TemplateBox[{"1", "x", "0", "3", "y", 
    RowBox[{"-", "x"}], 
    SuperscriptBox["x", "2"]},
   "InactiveIntegrate",
   DisplayFunction->(RowBox[{
      SubsuperscriptBox[
       StyleBox["\[Integral]", "Inactive"], #3, #4], 
      RowBox[{
        SubsuperscriptBox[
         StyleBox["\[Integral]", "Inactive"], #6, #7], 
        RowBox[{#, 
          RowBox[{
            StyleBox["\[DifferentialD]", "Inactive"], #5}], 
          RowBox[{
            StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]}]& ),
   InterpretationFunction->(RowBox[{
      RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
      RowBox[{#, ",", 
        RowBox[{"{", 
          RowBox[{#2, ",", #3, ",", #4}], "}"}], ",", 
        RowBox[{"{", 
          RowBox[{#5, ",", #6, ",", #7}], "}"}]}], "]"}]& )], "\[Equal]", 
  FractionBox["27", "2"]}]], "Output",
 CellChangeTimes->{{3.9888101986291447`*^9, 3.9888102174415417`*^9}, 
   3.988810298708027*^9, 3.9888103622332363`*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"219f5b35-07e3-4245-a261-2aeff5157b05"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"integrand", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mB", "=", 
   RowBox[{"{", 
    RowBox[{"z", ",", 
     RowBox[{"2", "x"}], ",", "5"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
