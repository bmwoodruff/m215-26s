Cell[BoxData[{
 RowBox[{
  RowBox[{"r", "[", "\[Theta]_", "]"}], ":=", 
  RowBox[{"7", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"4", "\[Theta]"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
