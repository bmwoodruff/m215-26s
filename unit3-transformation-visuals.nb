a10b241a9ce0"],

Cell["\<\
Now we create the transformed region in the xy-plane, with coloring to match \
the r\[Theta]-plane.\
\>", "Text",
 CellChangeTimes->{{3.988827147441086*^9, 
  3.9888271715303593`*^9}},ExpressionUUID->"0d395891-b440-8e49-a9d3-\
7a3e59d5e09f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xyPlot", "[", 
   RowBox[{"maxr_", ",", "max\[Theta]_", ",", "dr_", ",", "d\[Theta]_"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "0", ",", "maxr"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", "max\[Theta]"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Mesh", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Ceiling", "[", 
         RowBox[{"maxr", "/", "dr"}], "]"}], "-", "1"}], ",", 
       RowBox[{
        RowBox[{"Ceiling", "[", 
         RowBox[{"max\[Theta]", "/", "d\[Theta]"}], "]"}], "-", "1"}]}], 
      "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"MeshStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Red"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MeshShading", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"None", ",", "None"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9888232640144672`*^9, 3.9888232760189896`*^9}, {
   3.9888233973904495`*^9, 3.988823642026745*^9}, {3.988823773285013*^9, 
