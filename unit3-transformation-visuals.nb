24e6819678fc"],

Cell["\<\
We want to track how a box in the r\[Theta]-plane transformed in the xy \
plane.  So let\[CloseCurlyQuote]s draw the edges of that box. \
\>", "Text",
 CellChangeTimes->{{3.9888271184519444`*^9, 3.988827143364319*^9}, 
   3.988827178041483*^9},ExpressionUUID->"277e983b-1acd-764f-be29-\
0d2fad34e372"],

Cell[BoxData[
 RowBox[{
  RowBox[{"originalBox", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", "dr_", ",", "d\[Theta]_"}], "]"}], ":=",
   "\[IndentingNewLine]", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"Red", ",", 
     RowBox[{"Arrow", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "r"}], "}"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", "r"}], "}"}], "+", 
         RowBox[{"{", 
          RowBox[{"0", ",", "dr"}], "}"}]}]}], "}"}], "]"}], ",", 
     "\[IndentingNewLine]", "Blue", ",", 
     RowBox[{"Arrow", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "r"}], "}"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Theta]", ",", "r"}], "}"}], "+", 
         RowBox[{"{", 
          RowBox[{"d\[Theta]", ",", "0"}], "}"}]}]}], "}"}], "]"}], ",", 
     "\[IndentingNewLine]", "Purple", ",", 
     RowBox[{"Opacity", "[", "0.2", "]"}], ",", 
     RowBox[{"Parallelogram", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "r"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "dr"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"d\[Theta]", ",", "0"}], "}"}]}], "}"}]}], "]"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9888232640144672`*^9, 3.9888232760189896`*^9}, {
   3.9888233973904495`*^9, 3.988823642026745*^9}, {3.988823773285013*^9, 
