Cell["\<\
Create a plot in the r\[Theta]-plane. It\[CloseCurlyQuote]s not very \
exciting, but the color scheme setup is there to match the transformed \
versions later. \
\>", "Text",
 CellChangeTimes->{{3.988827083064625*^9, 3.98882711395253*^9}, 
   3.988827174775156*^9},ExpressionUUID->"eff09e15-2ed3-9541-9235-\
17649cc27581"],

Cell[BoxData[
 RowBox[{
  RowBox[{"r\[Theta]Plot", "[", 
   RowBox[{"maxr_", ",", "max\[Theta]_", ",", "dr_", ",", "d\[Theta]_"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "r"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "0", ",", "maxr"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", "max\[Theta]"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Mesh", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Ceiling", "[", 
         RowBox[{"maxr", "/", "dr"}], "]"}], "-", "1"}], ",", 
       RowBox[{
        RowBox[{"Ceiling", "[", 
         RowBox[{"max\[Theta]", "/", "d\[Theta]"}], "]"}], "-", "1"}]}], 
      "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"MeshStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Red"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"MeshShading", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"None", ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"None", ",", "None"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<\[Theta]\>\"", ",", "\"\<r\>\""}], "}"}]}]}], 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9888232640144672`*^9, 3.9888232760189896`*^9}, {
   3.9888233973904495`*^9, 3.988823642026745*^9}, {3.988823773285013*^9, 
   3.988823814973837*^9}, {3.9888243561628857`*^9, 3.9888243676523514`*^9}, 
   3.988824419418127*^9, {3.9888244526207085`*^9, 3.9888245214152794`*^9}, {
