19ded7000156"],

Cell["\<\
These helper function make creating the transformed parallelogram simpler. \
\>", "Text",
 CellChangeTimes->{{3.988827183229088*^9, 
  3.988827203311037*^9}},ExpressionUUID->"c8b9f74b-77c6-3d4f-a573-\
8afcd4db5d2e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"xycoord", "[", 
   RowBox[{"r_", ",", "\[Theta]_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"r", " ", 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"r", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"changeinr", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", "dr_", ",", "d\[Theta]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "}"}], "dr"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"changein\[Theta]", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", "dr_", ",", "d\[Theta]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "r"}], " ", 
      RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"r", " ", 
      RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}], 
   "d\[Theta]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9888232640144672`*^9, 3.9888232760189896`*^9}, {
   3.9888233973904495`*^9, 3.988823642026745*^9}, {3.988823773285013*^9, 
   3.988823814973837*^9}, {3.9888243561628857`*^9, 3.9888243676523514`*^9}, 
