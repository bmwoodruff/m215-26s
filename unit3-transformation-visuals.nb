75fe65a5271a"],

Cell["\<\
Now create the parallelogram that we\[CloseCurlyQuote]re using to approximate \
the actual transformed sector, as well as the transformed sector. \
\>", "Text",
 CellChangeTimes->{{3.9888272070749207`*^9, 
  3.988827243556759*^9}},ExpressionUUID->"a06dac0d-18ed-2d4e-a8d5-\
c611d44b08cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"transformedBox", "[", 
   RowBox[{"r_", ",", "\[Theta]_", ",", "dr_", ",", "d\[Theta]_"}], "]"}], ":=",
   "\[IndentingNewLine]", 
  RowBox[{"Graphics", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"Red", ",", 
     RowBox[{"Arrow", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xycoord", "[", 
         RowBox[{"r", ",", "\[Theta]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"xycoord", "[", 
          RowBox[{"r", ",", "\[Theta]"}], "]"}], "+", 
         RowBox[{"changeinr", "[", 
          RowBox[{"r", ",", "\[Theta]", ",", "dr", ",", "d\[Theta]"}], 
          "]"}]}]}], "}"}], "]"}], ",", "\[IndentingNewLine]", "Blue", ",", 
     RowBox[{"Arrow", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xycoord", "[", 
         RowBox[{"r", ",", "\[Theta]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"xycoord", "[", 
          RowBox[{"r", ",", "\[Theta]"}], "]"}], "+", 
         RowBox[{"changein\[Theta]", "[", 
          RowBox[{"r", ",", "\[Theta]", ",", "dr", ",", "d\[Theta]"}], 
          "]"}]}]}], "}"}], "]"}], ",", "\[IndentingNewLine]", "Purple", ",", 
     RowBox[{"Opacity", "[", "0.2", "]"}], ",", 
     RowBox[{"Parallelogram", "[", 
      RowBox[{
       RowBox[{"xycoord", "[", 
        RowBox[{"r", ",", "\[Theta]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"changeinr", "[", 
          RowBox[{"r", ",", "\[Theta]", ",", "dr", ",", "d\[Theta]"}], "]"}], 
         ",", 
         RowBox[{"changein\[Theta]", "[", 
          RowBox[{"r", ",", "\[Theta]", ",", "dr", ",", "d\[Theta]"}], 
          "]"}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", "}"}], 
   "]"}]}]], "Input",
 InitializationCell->True,
