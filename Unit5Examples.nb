Cell["We can also compute center of mass.", "Text",
 CellChangeTimes->{{3.991316894232567*^9, 3.9913169020303726`*^9}, {
  3.9913170427220917`*^9, 
  3.991317048721855*^9}},ExpressionUUID->"48393e26-dc5e-3445-82fc-\
6988e6f07e64"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"density", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "a"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", 
     RowBox[{"b", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"x", "/", "a"}]}], ")"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"massIntegral", " ", "=", 
   RowBox[{
    RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
    RowBox[{"density", ",", "oB", ",", "iB"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"massIntegral", " ", "==", 
   RowBox[{"Activate", "[", "massIntegral", "]"}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{"xbar", "=", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"x", " ", "density"}], ",", "oB", ",", "iB"}], "]"}], "/", 
   RowBox[{"Integrate", "[", 
    RowBox[{"density", ",", "oB", ",", "iB"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ybar", "=", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"y", " ", "density"}], ",", "oB", ",", "iB"}], "]"}], "/", 
    RowBox[{"Integrate", "[", 
     RowBox[{"density", ",", "oB", ",", "iB"}], "]"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
  RowBox[{"coords", ",", " ", "oB", ",", "iB"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9913169048687286`*^9, 3.991316910054308*^9}, {
  3.991316991620407*^9, 3.991317175833378*^9}},
 CellLabel->
  "In[134]:=",ExpressionUUID->"d328a74e-d5e1-634c-84cf-5cd24372acd0"],

Cell[BoxData[
 RowBox[{
  TemplateBox[{"1", "x", "0", "a", "y", "0", 
    RowBox[{"b", " ", 
      RowBox[{"(", 
        RowBox[{"1", "-", 
          FractionBox["x", "a"]}], ")"}]}]},
   "InactiveIntegrate",
   DisplayFunction->(RowBox[{
      SubsuperscriptBox[
       StyleBox["\[Integral]", "Inactive"], #3, #4], 
      RowBox[{
        SubsuperscriptBox[
         StyleBox["\[Integral]", "Inactive"], #6, #7], 
        RowBox[{#, 
          RowBox[{
            StyleBox["\[DifferentialD]", "Inactive"], #5}], 
          RowBox[{
            StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]}]& ),
   InterpretationFunction->(RowBox[{
      RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
      RowBox[{#, ",", 
        RowBox[{"{", 
          RowBox[{#2, ",", #3, ",", #4}], "}"}], ",", 
        RowBox[{"{", 
          RowBox[{#5, ",", #6, ",", #7}], "}"}]}], "]"}]& )], "\[Equal]", 
  FractionBox[
   RowBox[{"a", " ", "b"}], "2"]}]], "Output",
 CellChangeTimes->{{3.9913171364977837`*^9, 3.9913171461159325`*^9}, 
   3.991317176825119*^9},
 CellLabel->
  "Out[139]=",ExpressionUUID->"165ac5d1-3932-0f41-8dc9-410d81102b66"],

