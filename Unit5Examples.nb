Cell[CellGroupData[{
Cell["Unit 5 Topics", "Subtitle",
 CellChangeTimes->{{3.991315825635271*^9, 
  3.991315848996208*^9}},ExpressionUUID->"e0b1a3db-e3a0-4d4c-8a48-\
95ea3e60db71"],

Cell["Initialization Cells", "Section",
 CellChangeTimes->{{3.991315858369047*^9, 
  3.9913158754916935`*^9}},ExpressionUUID->"deb15308-a30c-4f45-924e-\
189543cfcadd"],

Cell[CellGroupData[{

Cell["Integrals", "Section",
 CellChangeTimes->{{3.991315852469681*^9, 
  3.9913158534407444`*^9}},ExpressionUUID->"1fc12ebd-38fa-3544-8faa-\
ea1136fe4265"],

Cell["\<\
This code will compute any double integral and draw the region. I use \
Inactive[ ] so that I can see the integral setup to check that I typed things \
correctly. \
\>", "Text",
 CellChangeTimes->{{3.9913168215455074`*^9, 
  3.991316873664255*^9}},ExpressionUUID->"4115264a-620d-a841-8f1d-\
615689d95bfb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"integrand", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", 
     RowBox[{"1", "-", 
      RowBox[{"x", "^", "2"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"areaIntegral", " ", "=", 
   RowBox[{
    RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
    RowBox[{"integrand", ",", "oB", ",", "iB"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"areaIntegral", " ", "==", 
   RowBox[{"Activate", "[", "areaIntegral", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
  RowBox[{"coords", ",", " ", "oB", ",", "iB"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.99131588026569*^9, 3.991315960454565*^9}, {
  3.9913160283644066`*^9, 3.991316073328863*^9}, {3.991316144630188*^9, 
  3.9913161599800873`*^9}, {3.9913162036544704`*^9, 3.991316358930624*^9}, {
  3.991316848498045*^9, 3.991316848881922*^9}, {3.9913169456455517`*^9, 
  3.991316946571884*^9}, {3.99131706872624*^9, 3.9913170699914494`*^9}, {
  3.9913181723450794`*^9, 
  3.9913181820592594`*^9}},ExpressionUUID->"54019bd1-2ada-ef42-bdad-\
b571d862fe0c"],

Cell[BoxData[
 RowBox[{
  TemplateBox[{"1", "x", "0", "1", "y", "0", 
    RowBox[{"1", "-", 
      SuperscriptBox["x", "2"]}]},
   "InactiveIntegrate",
   DisplayFunction->(RowBox[{
      SubsuperscriptBox[
       StyleBox["\[Integral]", "Inactive"], #3, #4], 
      RowBox[{
        SubsuperscriptBox[
         StyleBox["\[Integral]", "Inactive"], #6, #7], 
        RowBox[{#, 
          RowBox[{
            StyleBox["\[DifferentialD]", "Inactive"], #5}], 
          RowBox[{
            StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]}]& ),
   InterpretationFunction->(RowBox[{
      RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
      RowBox[{#, ",", 
        RowBox[{"{", 
          RowBox[{#2, ",", #3, ",", #4}], "}"}], ",", 
        RowBox[{"{", 
          RowBox[{#5, ",", #6, ",", #7}], "}"}]}], "]"}]& )], "\[Equal]", 
  FractionBox["2", "3"]}]], "Output",
 CellChangeTimes->{3.991316942326975*^9, 3.991318115083391*^9},
 CellLabel->
  "Out[170]=",ExpressionUUID->"845beff3-3fa1-e444-88a4-4f06b03c6914"],

