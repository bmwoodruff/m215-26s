Cell["Integrals in 2D", "Section",
 CellChangeTimes->{{3.991315852469681*^9, 3.9913158534407444`*^9}, {
  3.9913182474157887`*^9, 
  3.9913182493371754`*^9}},ExpressionUUID->"1fc12ebd-38fa-3544-8faa-\
ea1136fe4265"],

Cell["If you just want to compute something quickly, then here.", "Text",
 CellChangeTimes->{{3.991318259047245*^9, 
  3.9913182686826534`*^9}},ExpressionUUID->"38d037df-b421-9940-8a07-\
e386092837e7"],

Cell[BoxData[{
 RowBox[{"area", " ", "=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{"1", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "a"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", 
      RowBox[{"b", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"x", "/", "a"}]}], ")"}]}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"xbar", " ", "=", " ", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{"x", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "a"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "0", ",", 
       RowBox[{"b", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"x", "/", "a"}]}], ")"}]}]}], "}"}]}], "]"}], "/", 
   "area"}]}], "\[IndentingNewLine]", 
 RowBox[{"ybar", " ", "=", " ", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{"y", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "a"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"y", ",", "0", ",", 
       RowBox[{"b", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"x", "/", "a"}]}], ")"}]}]}], "}"}]}], "]"}], "/", 
   "area"}]}]}], "Input",
 CellChangeTimes->{{3.9913177251657944`*^9, 3.991317758244644*^9}, {
  3.99131779130151*^9, 3.991317862369011*^9}, {3.9913205720611687`*^9, 
  3.9913205911302357`*^9}, {3.991320622942629*^9, 3.9913206615472794`*^9}, {
  3.99132157933391*^9, 3.9913215805734825`*^9}, {3.9913217431579704`*^9, 
  3.9913218255650177`*^9}},
 CellLabel->
  "In[208]:=",ExpressionUUID->"7bb5eb4f-d2d9-9e4c-a669-0b2ba7fe0801"],

Cell["You can compute both xbar and ybar at once", "Text",
 CellChangeTimes->{
  3.991321593463745*^9},ExpressionUUID->"b6039c81-4e92-ca42-a623-\
0992827d6ada"],

Cell[BoxData[{
 RowBox[{"area", " ", "=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{"1", ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "a"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", 
      RowBox[{"b", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"x", "/", "a"}]}], ")"}]}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "a"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", 
      RowBox[{"b", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"x", "/", "a"}]}], ")"}]}]}], "}"}]}], "]"}], "/", 
  "area"}]}], "Input",
 CellChangeTimes->{{3.991321613404127*^9, 3.9913216136752872`*^9}, {
  3.9913217970770054`*^9, 3.9913218010411816`*^9}, {3.9913218366421013`*^9, 
  3.9913218393345604`*^9}},
 CellLabel->
  "In[219]:=",ExpressionUUID->"f392cfd2-97c5-1443-9b7f-2424c7e9a9da"],

Cell["Here\[CloseCurlyQuote]s an example in polar coordinates.", "Text",
 CellChangeTimes->{{3.9913183171854153`*^9, 
  3.9913183232119846`*^9}},ExpressionUUID->"ebd709a8-823a-2f41-97fd-\
7a7fa6b7a598"],

Cell[BoxData[{
 RowBox[{"area", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{"r", ",", 
    RowBox[{"{", 
     RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"r", ",", "0", ",", "a"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"xbar", " ", "=", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"r", " ", 
        RowBox[{"Cos", "[", "theta", "]"}]}], ")"}], "r"}], ",", 
     RowBox[{"{", 
      RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "a"}], "}"}]}], "]"}], "/", "area"}]}], "\[IndentingNewLine]", 
 RowBox[{"ybar", " ", "=", " ", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"r", " ", 
        RowBox[{"Sin", "[", "theta", "]"}]}], ")"}], "r"}], ",", 
     RowBox[{"{", 
      RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "a"}], "}"}]}], "]"}], "/", 
   "area"}]}]}], "Input",
 CellChangeTimes->{{3.9913179130873814`*^9, 3.991317982266575*^9}, {
  3.9913180248356266`*^9, 3.9913180270584755`*^9}},
 CellLabel->
  "In[172]:=",ExpressionUUID->"bae71204-f019-134b-84c0-9c57dfa0ed4c"],

Cell["\<\
This code will compute any double integral and draw the region. I use \
Inactive[ ] so that I can see the integral setup to check that I typed things \
correctly. \
\>", "Text",
 CellChangeTimes->{{3.9913168215455074`*^9, 
  3.991316873664255*^9}},ExpressionUUID->"4115264a-620d-a841-8f1d-\
615689d95bfb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"integrand", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "5"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", 
     RowBox[{"7", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"x", "/", "5"}]}], ")"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"areaIntegral", " ", "=", 
   RowBox[{
    RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
    RowBox[{"integrand", ",", "oB", ",", "iB"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"areaIntegral", " ", "==", 
   RowBox[{"Activate", "[", "areaIntegral", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
  RowBox[{"coords", ",", " ", "oB", ",", "iB"}], "]"}]}], "Input",
 CellChangeTimes->{{3.99131588026569*^9, 3.991315960454565*^9}, {
   3.9913160283644066`*^9, 3.991316073328863*^9}, {3.991316144630188*^9, 
   3.9913161599800873`*^9}, {3.9913162036544704`*^9, 3.991316358930624*^9}, {
   3.991316848498045*^9, 3.991316848881922*^9}, {3.9913169456455517`*^9, 
   3.991316946571884*^9}, {3.99131706872624*^9, 3.9913170699914494`*^9}, {
   3.9913181723450794`*^9, 3.9913181820592594`*^9}, {3.991322081767164*^9, 
   3.9913220846405983`*^9}, {3.9913221551160984`*^9, 
   3.9913221614928684`*^9}, {3.9913224355919056`*^9, 3.9913224579347706`*^9}, 
   3.9913225680615177`*^9},ExpressionUUID->"54019bd1-2ada-ef42-bdad-\
b571d862fe0c"],

Cell["We can also compute center of mass.", "Text",
 CellChangeTimes->{{3.991316894232567*^9, 3.9913169020303726`*^9}, {
  3.9913170427220917`*^9, 
  3.991317048721855*^9}},ExpressionUUID->"48393e26-dc5e-3445-82fc-\
6988e6f07e64"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"density", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "a"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", 
     RowBox[{"b", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"x", "/", "a"}]}], ")"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"massIntegral", " ", "=", 
   RowBox[{
    RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
    RowBox[{"density", ",", "oB", ",", "iB"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"massIntegral", " ", "==", 
   RowBox[{"Activate", "[", "massIntegral", "]"}]}], " "}], "\[IndentingNewLine]", 
 RowBox[{"xbar", "=", 
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"x", " ", "density"}], ",", "oB", ",", "iB"}], "]"}], "/", 
   RowBox[{"Integrate", "[", 
    RowBox[{"density", ",", "oB", ",", "iB"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ybar", "=", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"y", " ", "density"}], ",", "oB", ",", "iB"}], "]"}], "/", 
    RowBox[{"Integrate", "[", 
     RowBox[{"density", ",", "oB", ",", "iB"}], "]"}]}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Both", " ", "can", " ", "be", " ", "done", " ", "at", " ", 
    RowBox[{"once", ".", " ", "Use"}], " ", "a", " ", 
    RowBox[{"vector", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], " ", "density"}], ",", "oB", ",", 
     "iB"}], "]"}], "/", 
   RowBox[{"Integrate", "[", 
    RowBox[{"density", ",", "oB", ",", "iB"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
  RowBox[{"coords", ",", " ", "oB", ",", "iB"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9913169048687286`*^9, 3.991316910054308*^9}, {
  3.991316991620407*^9, 3.991317175833378*^9}, {3.991318334130224*^9, 
  3.9913183738084774`*^9}},ExpressionUUID->"d328a74e-d5e1-634c-84cf-\
5cd24372acd0"],

Cell["\<\
Now let\[CloseCurlyQuote]s try a polar coordinate problem. The hardest part \
is learning to set up the integral, so I\[CloseCurlyQuote]ll leave the center \
of mass out. \
\>", "Text",
 CellChangeTimes->{{3.99131688747353*^9, 3.9913168893243866`*^9}, {
  3.991317633313244*^9, 3.9913176410973682`*^9}, {3.9913184013626175`*^9, 
  3.991318429269785*^9}},ExpressionUUID->"6adad9ea-3774-db4d-b11f-\
97151eb24099"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"integrand", "=", "r"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"theta", ",", "0", ",", "Pi"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
   RowBox[{"{", 
    RowBox[{"r", ",", "0", ",", "5"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", "theta", "]"}]}], ",", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "theta", "]"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"areaIntegral", " ", "=", 
   RowBox[{
    RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
    RowBox[{"integrand", ",", "oB", ",", "iB"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"areaIntegral", " ", "==", 
   RowBox[{"Activate", "[", "areaIntegral", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
  RowBox[{"coords", ",", " ", "oB", ",", "iB"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9913176443328876`*^9, 3.991317672000374*^9}, {
  3.991322248911707*^9, 3.991322320205492*^9}},
 CellLabel->
  "In[252]:=",ExpressionUUID->"2e9d77ae-ea62-2449-b093-1519d92398f3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Integrals in 3D", "Section",
 CellChangeTimes->{{3.991322594499277*^9, 
  3.9913226033440857`*^9}},ExpressionUUID->"b77f40a1-b271-dc4c-a485-\
b3689d4e8e2c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"oB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "5"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "7"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"iB", "=", 
   RowBox[{"{", 
    RowBox[{"z", ",", "0", ",", 
     RowBox[{"10", "-", 
      RowBox[{"2", "x"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], ";"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Compute", " ", "a", " ", "simple", " ", "basic", " ", 
    RowBox[{"integral", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{"1", ",", "oB", ",", "mB", ",", "iB"}], "]"}], " ", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Give", " ", "me", " ", "a", " ", "visual", " ", "to", " ", "check", " ", 
    "for", " ", "possible", " ", 
    RowBox[{"errors", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"volumeIntegral", " ", "=", " ", 
   RowBox[{
    RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
    RowBox[{"1", ",", "oB", ",", "mB", ",", "iB"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"volumeIntegral", "==", 
   RowBox[{"Activate", "[", "volumeIntegral", "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Draw", " ", "the", " ", 
    RowBox[{"region", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R", "=", 
   RowBox[{"ParametricRegion", "[", 
    RowBox[{"coords", ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{"{", 
       RowBox[{"oB", ",", "mB", ",", "iB"}], "}"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Region", "[", 
   RowBox[{"R", ",", 
    RowBox[{"Axes", "->", "True"}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], ",", 
    RowBox[{"AxesOrigin", "->", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0"}], "}"}]}]}], "]"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", "Centroid", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", "oB", ",", "mB", ",", 
    "iB"}], "]"}], " ", "/", 
  RowBox[{"Integrate", "[", 
   RowBox[{"1", ",", "oB", ",", "mB", ",", "iB"}], "]"}], " "}]}], "Input",
 CellChangeTimes->{{3.9913226115241737`*^9, 3.9913226156404705`*^9}, {
  3.9913227346868763`*^9, 3.9913227485637665`*^9}, {3.9913229763287163`*^9, 
