   RowBox[{"Evaluate", "[", "innerB", "]"}], ",", 
   RowBox[{"Mesh", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"10", ",", "0"}], "}"}]}]}], "]"}]}], "Input",
