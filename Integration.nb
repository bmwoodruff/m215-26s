  RowBox[{"r", ",", "\[Theta]", ",", "z"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", "z"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", "0", ",", 
     RowBox[{"Pi", "/", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"middleB", "=", 
   RowBox[{"{", 
    RowBox[{"r", ",", "1", ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"z", ",", "0", ",", 
      RowBox[{"9", "-", 
       RowBox[{"r", "^", "2"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"animateRegion3D", "[", 
  RowBox[{"coords", ",", "outerB", ",", "middleB", ",", "innerB"}], 
  "]"}]}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.4460272568934913`*^9, 3.4460272580050898`*^9}, {
  3.9834430101895638`*^9, 3.98344303127376*^9}},
