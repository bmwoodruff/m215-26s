Cell[CellGroupData[{

Cell["Double Integrals in Cartesian (Rectangular) Coordinates", "Section",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691638992403*^9, 
  3.750691672960208*^9}},ExpressionUUID->"c07cd9f5-f085-4764-9e90-\
