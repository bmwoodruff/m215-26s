Cell[CellGroupData[{

Cell["Plot", "Subsection",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.7506951318969593`*^9, 
  3.750695149624834*^9}},ExpressionUUID->"e16f74cb-f89d-4def-a413-\
66c2a049a5ea"],

Cell["\<\
The following code will construct a region plot in 2D of a region described \
by the bounds of a double integral using Cartesian coordinates.  Just supply \
the outerB and innerB. We use the ParametricPlot command (with two \
parameters) to do the graphing. The coordinate system is just (x,y)=(x,y) for \
Cartesian Coordinates. \
\>", "Text",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691353264286*^9, 3.7506914614726143`*^9}, {
  3.75069225880387*^9, 3.7506922953461657`*^9}, {3.7506929193226233`*^9, 
  3.7506929801868877`*^9}, {3.9834420645725307`*^9, 
  3.983442083661804*^9}},ExpressionUUID->"6500ce00-14a0-4a5f-84cd-\
a59bf2c09a20"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"x", ",", "y"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"outerB", "=", 
  RowBox[{"{", 
   RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"innerB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "x"}], ",", 
     RowBox[{"x", "^", "2"}]}], "}"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
  RowBox[{"coords", ",", "outerB", ",", "innerB", ",", 
   RowBox[{"Mesh", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"10", ",", "0"}], "}"}]}]}], "]"}]}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750690923824171*^9, 3.750690925426818*^9}, {
   3.750690968591851*^9, 3.7506912149153337`*^9}, {3.750691272978971*^9, 
   3.750691278482147*^9}, {3.750691471156376*^9, 3.750691552673985*^9}, {
   3.750692115556038*^9, 3.75069212449914*^9}, {3.750692159123789*^9, 
