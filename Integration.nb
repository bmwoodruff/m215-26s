   3.750694497422662*^9}, {3.750694751266212*^9, 3.7506947750870543`*^9}, {
   3.75069490406282*^9, 3.750694904558133*^9}, {3.750695043875704*^9, 
   3.750695047295627*^9}, 3.7506952957736197`*^9, {3.9834415866812553`*^9, 
