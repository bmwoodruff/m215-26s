Cell[CellGroupData[{

Cell["Compute Integral", "Subsection",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.7506951554968853`*^9, 
  3.750695188568738*^9}},ExpressionUUID->"ca54f798-2afc-4f3d-85fe-\
14a348e62889"],

Cell["\<\
The following code will compute a double integral. If the integrand is \
\[Rho]^2 Sin[\[Phi]], then for spherical coordinates you get the volume of \
the solid.\
\>", "Text",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691561488798*^9, 3.7506916126405897`*^9}, {
  3.750694801049268*^9, 
  3.750694840873292*^9}},ExpressionUUID->"92566039-e884-41ff-82e1-\
9c9c99a429ae"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"\[Rho]", ",", "\[Phi]", ",", "\[Theta]"}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "1", ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"middleB", "=", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", 
     RowBox[{"Pi", "/", "6"}], ",", 
     RowBox[{"Pi", "/", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", "Pi"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"integrand", "=", 
   RowBox[{
    RowBox[{"\[Rho]", "^", "2"}], " ", 
    RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{"integrand", ",", "outerB", ",", " ", "middleB", ",", "innerB"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"approximateSolution", " ", "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{"integrand", ",", "outerB", ",", "middleB", ",", " ", "innerB"}], 
    "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"showSetup", "[", 
   RowBox[{"integrand", ",", "outerB", ",", " ", "middleB", ",", "innerB"}], 
   "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691223173471*^9, 3.7506912670403347`*^9}, {
   3.750691297248672*^9, 3.750691338896779*^9}, {3.7506927320316267`*^9, 
   3.750692767578857*^9}, 3.750692804850916*^9, {3.75069367125904*^9, 
   3.750693784638983*^9}, {3.7506938839379053`*^9, 3.750693907853067*^9}, {
