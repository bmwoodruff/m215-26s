Cell[CellGroupData[{

Cell["Compute Integral", "Subsection",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.7506951554968853`*^9, 
  3.750695188568738*^9}},ExpressionUUID->"38399241-d499-42f0-954d-\
1e353acf056c"],

Cell["\<\
The following code will compute a double integral. If the integrand is 1 \
using x and y bounds, then you will compute the area of the region.\
\>", "Text",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691561488798*^9, 
  3.7506916126405897`*^9}},ExpressionUUID->"70f9a5af-2cb3-4ff8-a431-\
2a26a6b5a99d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"x", ",", "y"}], "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "x"}], ",", 
      RowBox[{"x", "^", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"integrand", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{"integrand", ",", "outerB", ",", " ", "innerB"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"approximateSolution", " ", "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{"integrand", ",", "outerB", ",", " ", "innerB"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"showSetup", "[", 
  RowBox[{"integrand", ",", "outerB", ",", " ", "innerB"}], "]"}]}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691223173471*^9, 3.7506912670403347`*^9}, {
