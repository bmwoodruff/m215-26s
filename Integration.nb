            RowBox[{"s", ",", "0", ",", "1"}], "}"}], ",", 
           RowBox[{"MeshShading", "\[Rule]", "None"}], ",", 
           RowBox[{"Mesh", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"21", ",", "0"}], "}"}]}], ",", 
           RowBox[{"PlotStyle", "\[Rule]", "None"}], ",", 
           RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], ",", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"ParametricPlot", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"rs", "/.", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"wIB", "[", 
