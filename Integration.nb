Cell[CellGroupData[{

Cell["Triple Integrals in Spherical Coordinates", "Section",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691638992403*^9, 3.7506916882087803`*^9}, {
  3.7506930052250834`*^9, 3.750693010041381*^9}, {3.7506940355130672`*^9, 
  3.7506940394172983`*^9}},ExpressionUUID->"052db310-e1b7-4d11-9406-\
cb75e50eee76"],

Cell[CellGroupData[{

Cell["Plot", "Subsection",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.7506951318969593`*^9, 
  3.750695149624834*^9}},ExpressionUUID->"2bc4a7a3-e077-4528-963e-\
fcea192efdea"],

Cell["\<\
The following code will draw a solid region described using triple integrals \
in Cartesian coordinates.  The code actually draws 6 surfaces (one for each \
inequality) and then puts them in the same plot. \
\>", "Text",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691353264286*^9, 3.7506914614726143`*^9}, {
  3.750692326196982*^9, 3.750692334741083*^9}, {3.750693024489408*^9, 
  3.7506930478493013`*^9}, {3.750693194681807*^9, 3.750693214601144*^9}, {
  3.7506935685537148`*^9, 3.7506935782967567`*^9}, {3.7506939430171947`*^9, 
  3.750693969193694*^9}},ExpressionUUID->"8cdddfc0-4f6e-40d4-97f2-\
7da77ec90656"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"\[Rho]", ",", "\[Phi]", ",", "\[Theta]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Rho]", " ", 
       RowBox[{"Sin", "[", "\[Phi]", "]"}], 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"\[Rho]", " ", 
       RowBox[{"Sin", "[", "\[Phi]", "]"}], 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"\[Rho]", " ", 
       RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "1", ",", "3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"middleB", "=", 
   RowBox[{"{", 
    RowBox[{"\[Phi]", ",", 
     RowBox[{"Pi", "/", "6"}], ",", 
     RowBox[{"Pi", "/", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", "Pi"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"plotRegion3D", "[", 
  RowBox[{"coords", ",", "outerB", ",", "middleB", ",", "innerB"}], 
  "]"}]}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750690923824171*^9, 3.750690925426818*^9}, {
   3.750690968591851*^9, 3.7506912149153337`*^9}, {3.750691272978971*^9, 
   3.750691278482147*^9}, {3.750691471156376*^9, 3.750691552673985*^9}, {
   3.750691694595461*^9, 3.7506917128499317`*^9}, {3.750692338885743*^9, 
   3.750692385710988*^9}, {3.750692813643342*^9, 3.750692839609606*^9}, {
   3.750693051721765*^9, 3.750693076233779*^9}, {3.750693144937819*^9, 
   3.750693147078776*^9}, {3.7506932206661386`*^9, 3.750693222110372*^9}, {
   3.750693274226461*^9, 3.750693292416666*^9}, {3.7506933324943523`*^9, 
   3.750693376619748*^9}, {3.750693460560361*^9, 3.750693525919751*^9}, {
   3.750693587645385*^9, 3.750693611042179*^9}, {3.750694285454524*^9, 
   3.750694361223721*^9}, {3.750694543295896*^9, 3.750694550388178*^9}, {
   3.750694680086022*^9, 3.750694738253948*^9}, {3.750694896975425*^9, 
   3.7506949117419233`*^9}, 3.750695839884006*^9, 3.762865685056724*^9, {
   3.9830106168138523`*^9, 3.9830106304315414`*^9}, {3.9834430488359547`*^9, 
   3.9834431142499676`*^9}, {3.983443169886133*^9, 3.9834432146503906`*^9}},
 CellLabel->
  "In[298]:=",ExpressionUUID->"ef2eca6b-87a2-4025-8cc9-c1d5375de714"]
