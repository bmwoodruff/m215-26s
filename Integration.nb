90ad2aa25b7a"],

Cell["\<\
The following code will compute a triple integral. If the integrand is 1 \
using Cartesian coordinates, then you will compute the volume of the region.\
\>", "Text",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691561488798*^9, 3.7506916126405897`*^9}, {
  3.750694228378152*^9, 
  3.750694248793468*^9}},ExpressionUUID->"dae14909-ccbb-43b0-9282-\
137c9d414d1a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"middleB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "4"}], "}"}]}], ";"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"z", ",", "0", ",", 
      RowBox[{"x", "^", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"integrand", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{"integrand", ",", "outerB", ",", " ", "middleB", ",", "innerB"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"approximateSolution", " ", "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{"integrand", ",", "outerB", ",", "middleB", ",", " ", "innerB"}], 
    "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"showSetup", "[", 
  RowBox[{"integrand", ",", "outerB", ",", " ", "middleB", ",", "innerB"}], 
  "]"}]}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691223173471*^9, 3.7506912670403347`*^9}, {
