  3.7506935685537148`*^9, 3.7506935782967567`*^9}, {3.7506939430171947`*^9, 
  3.750693969193694*^9}},ExpressionUUID->"a5b63c31-5f00-46fb-932e-\
06c19a1d2692"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"x", ",", "y", ",", "z"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"middleB", "=", 
   RowBox[{"{", 
    RowBox[{"y", ",", "0", ",", "4"}], "}"}]}], ";"}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"z", ",", "0", ",", 
      RowBox[{"x", "^", "2"}]}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"plotRegion3D", "[", 
  RowBox[{"coords", ",", "outerB", ",", "middleB", ",", "innerB"}], 
  "]"}]}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->CompressedData["
