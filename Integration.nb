      "\[IndentingNewLine]", 
     RowBox[{"wIB", "=", "IB"}], ";", 
     RowBox[{"wOB", "=", "OB"}], ";", 
     RowBox[{"wMB", "=", "MB"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Show", "[", 
      RowBox[{"{", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ParametricPlot", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"rr", "/.", 
