Cell[CellGroupData[{

Cell["Bounds Animation", "Subsection",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.7506951554968853`*^9, 3.750695188568738*^9}, {
  3.815731955447661*^9, 
  3.815731961351335*^9}},ExpressionUUID->"c2321da1-274a-44f8-a075-\
1ef01300402c"],

Cell["\<\
This block of code helps with visualizing polar coordinate smashing.  Notice \
that smashing r to 0 means you would smash the entire graph to a point. \
Instead, pick a nonzero radius and smash the entire graph to that radius \
(kind of like inserting a balloon at the origin, while compressing from the \
exterior).  If you can place the theta bound as the inner variable, then \
viewing the region is similar to folding up (or unfolding) a fan.\
\>", "Text",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.4459136825980835`*^9, 
  3.445913824071512*^9}},ExpressionUUID->"92e2e7e6-35e8-4819-9ddc-\
b268939cd503"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"r", ",", "\[Theta]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", "0", ",", 
     RowBox[{"2", "Pi"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"r", ",", "0", ",", 
      RowBox[{"1", "-", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"animateRegion2D", "[", 
  RowBox[{"coords", ",", "outerB", ",", "innerB"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.445911007171008*^9, 3.44591103375924*^9}, {
   3.445911118260747*^9, 3.4459111227872562`*^9}, {3.4459111531809597`*^9, 
   3.44591115718672*^9}, {3.4459112061471214`*^9, 3.4459112445223026`*^9}, {
   3.445911357654979*^9, 3.4459115446839137`*^9}, {3.445911582718605*^9, 
   3.4459115925126877`*^9}, 3.4459116603402195`*^9, {3.445911821632146*^9, 
   3.445911827100008*^9}, 3.445912021199109*^9, {3.445912072352664*^9, 
   3.4459122039518943`*^9}, {3.4459131865447936`*^9, 
   3.4459131947566013`*^9}, {3.4459133313730464`*^9, 
   3.4459133532645245`*^9}, {3.445913386772707*^9, 3.445913388475155*^9}, {
   3.446820492230485*^9, 3.446820584968459*^9}, {3.446858036201355*^9, 
   3.4468580422901106`*^9}, {3.4468582342962017`*^9, 3.446858236228981*^9}, {
   3.983442497232355*^9, 3.983442536685961*^9}},
 CellLabel->
