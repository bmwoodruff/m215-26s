Cell["Compute Integral", "Subsection",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.7506951554968853`*^9, 
  3.750695188568738*^9}},ExpressionUUID->"e670ab7e-7d85-4c6e-b2e1-\
9d93a083e6cc"],

Cell["\<\
The following code will compute a double integral. If the integrand is r (the \
Jacobian) using r and \[Theta] bounds, then you will compute the area of the \
region. A plot of the region is also provided. \
\>", "Text",
 ShowGroupOpener->True,
 CellChangeTimes->{{3.750691561488798*^9, 3.7506916126405897`*^9}, {
  3.750692592777494*^9, 3.750692603784903*^9}, {3.750692874681629*^9, 
  3.75069289901816*^9}},ExpressionUUID->"972e656c-bd63-413f-a9d2-\
4ce2dc95dc75"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"r", ",", "\[Theta]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"coords", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"r", " ", 
       RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerB", "=", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", 
     RowBox[{"Pi", "/", "4"}], ",", "Pi"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"innerB", "=", 
    RowBox[{"{", 
     RowBox[{"r", ",", "2", ",", "5"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"integrand", "=", "r"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Integrate", "[", 
  RowBox[{"integrand", ",", "outerB", ",", " ", "innerB"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"approximateSolution", " ", "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{"integrand", ",", "outerB", ",", " ", "innerB"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"showSetup", "[", 
  RowBox[{"integrand", ",", "outerB", ",", " ", "innerB"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 ShowGroupOpener->True,
