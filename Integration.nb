   RowBox[{"{", 
    RowBox[{"r", ",", "2", ",", "5"}], "}"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ParametricPlot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", "coords", "]"}], ",", 
